# Production env for docker-compose. Copy to ".env" ON THE SERVER and fill in.
# (docker compose auto-loads ".env" for both interpolation and the web container.)

# --- Database ---
POSTGRES_USER=life
POSTGRES_PASSWORD=change-this-strong-password
POSTGRES_DB=life

# --- Auth.js (REQUIRED) — generate with: openssl rand -base64 32 ---
AUTH_SECRET=
AUTH_URL=https://life.innertalk.space

# --- Domain for Caddy / TLS ---
DOMAIN=life.innertalk.space

# --- AI provider: claude | openai | mock (mock needs no key) ---
AI_PROVIDER=mock
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o
