# Production env for docker-compose. Copy to ".env" ON THE SERVER and fill in.
# (docker compose auto-loads ".env" for both interpolation and the web container.)

# --- Database ---
POSTGRES_USER=life
POSTGRES_PASSWORD=change-this-strong-password
POSTGRES_DB=life

# --- Auth.js (REQUIRED) — generate with: openssl rand -base64 32 ---
AUTH_SECRET=
AUTH_URL=https://life.innertalk.space

# --- Domain for Caddy / TLS ---
DOMAIN=life.innertalk.space

# --- AI provider: deepseek | claude | openai | mock (mock needs no key) ---
AI_PROVIDER=deepseek

# DeepSeek via VseGPT / OpenRouter (OpenAI-compatible gateway)
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.vsegpt.ru/v1
DEEPSEEK_MODEL=deepseek/deepseek-chat

ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o
