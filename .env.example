# Copy to .env and fill in. Never commit real secrets.

# PostgreSQL connection string
DATABASE_URL="postgresql://life:life@localhost:5432/life?schema=public"

# Auth.js (NextAuth v5). Generate with: openssl rand -base64 32
AUTH_SECRET="change-me"
# Needed behind a reverse proxy / in Docker:
AUTH_TRUST_HOST=true
# In production set the canonical URL:
# AUTH_URL=https://life.innertalk.space

# Which AI builds the roadmap: claude | openai | mock
# If the selected provider has no API key, the app falls back to "mock".
AI_PROVIDER=mock

# Anthropic Claude
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6

# OpenAI
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o
