// Prisma schema for "Life" — the self-development game.
// Provider is PostgreSQL in every environment. Enum-like fields are stored as
// String and validated in the app layer (Zod) so the schema stays portable and
// migrations stay friction-free.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String            @id @default(cuid())
  email        String            @unique
  name         String?
  passwordHash String
  createdAt    DateTime          @default(now())
  character    Character?
  goals        Goal[]
  achievements UserAchievement[]
  activity     ActivityLog[]
  roomItems    RoomItem[]
}

model Character {
  id         String          @id @default(cuid())
  userId     String          @unique
  user       User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  name       String
  appearance Json // { body, hair, hairColor, outfit, outfitColor }
  level      Int             @default(1)
  xp         Int             @default(0) // total accumulated xp
  gold       Int             @default(0)
  createdAt  DateTime        @default(now())
  stats      Stat[]
  inventory  InventoryItem[]
}

model Stat {
  id          String    @id @default(cuid())
  characterId String
  character   Character @relation(fields: [characterId], references: [id], onDelete: Cascade)
  domain      String // fitness | career | wellbeing | knowledge
  value       Int       @default(0) // domain xp
  level       Int       @default(1)

  @@unique([characterId, domain])
}

model Goal {
  id           String    @id @default(cuid())
  userId       String
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  domain       String
  title        String
  description  String    @default("")
  motivation   String    @default("") // the "why"
  currentState String    @default("")
  targetDate   DateTime?
  hoursPerWeek Int       @default(3)
  status       String    @default("active") // active | done | archived
  completedAt  DateTime?
  createdAt    DateTime  @default(now())
  tasks        GoalTask[]
}

// AI-generated (or manual) mini-task / step toward a goal. The user checks
// these off or removes them.
model GoalTask {
  id          String    @id @default(cuid())
  goalId      String
  goal        Goal      @relation(fields: [goalId], references: [id], onDelete: Cascade)
  title       String
  done        Boolean   @default(false)
  order       Int       @default(0)
  source      String    @default("ai") // ai | manual
  xpReward    Int       @default(20)
  goldReward  Int       @default(5)
  completedAt DateTime?
  createdAt   DateTime  @default(now())

  @@index([goalId])
}

model AchievementDef {
  key           String            @id
  title         String
  description   String
  icon          String            @default("🏆")
  conditionType String // first_quest | quests_completed | level | domain_level | gold_earned
  threshold     Int               @default(0)
  domain        String?
  unlocked      UserAchievement[]
}

model UserAchievement {
  id         String         @id @default(cuid())
  userId     String
  user       User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  key        String
  def        AchievementDef @relation(fields: [key], references: [key])
  unlockedAt DateTime       @default(now())

  @@unique([userId, key])
}

model InventoryItem {
  id          String    @id @default(cuid())
  characterId String
  character   Character @relation(fields: [characterId], references: [id], onDelete: Cascade)
  itemKey     String
  kind        String // furniture | cosmetic | gear | trophy
  name        String
  cost        Int       @default(0)
  source      String    @default("shop") // shop | real_purchase | reward
  acquiredAt  DateTime  @default(now())
}

model ActivityLog {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      String // quest_complete | level_up | achievement | purchase | real_achievement | real_purchase
  payload   Json
  createdAt DateTime @default(now())
}

// User-placed furniture inside a location's interior.
model RoomItem {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  locationKey String // home | gym | work | study
  itemKey     String
  x           Int
  y           Int
  createdAt   DateTime @default(now())

  @@index([userId, locationKey])
}
